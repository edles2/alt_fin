# Copy this file to .env and fill in your values.
# Never commit .env — it is listed in .gitignore.

# Infura project ID — required for any blockchain interaction.
# Free account at https://app.infura.io
INFURA_PROJECT_ID=your_infura_project_id_here

# Private key of the wallet that holds the reward tokens.
# Required only when sending tokens (TokenTransfer).
PRIVATE_KEY=your_wallet_private_key_here
